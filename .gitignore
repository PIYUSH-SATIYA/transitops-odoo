# ==========================================
# Dependencies (Never commit node_modules)
# ==========================================
**/node_modules/
**/jspm_packages/
**/web_modules/
.pnpm-store/

# ==========================================
# Production / Build Artifacts
# ==========================================
# React production builds (CRA, Vite, Next.js, etc.)
**/dist/
**/build/
**/out/
**/.next/

# Node.js backend compilation output (if using TypeScript/Babel)
**/lib/
**/dist-server/

# ==========================================
# Environment Variables & Secrets (CRITICAL)
# ==========================================
**.env
**.env.local
**.env.development.local
**.env.test.local
**.env.production.local
**.env*.local
*.pem
*.key

# ==========================================
# Logs and Runtime Files
# ==========================================
*.log
**/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
pid
*.pid
*.seed
*.pid.lock

# ==========================================
# Testing & Coverage
# ==========================================
**/coverage/
**/.nyc_output/
**/.jest/

# ==========================================
# IDEs, Editors, & OS Specific Files
# ==========================================
.editorconfig
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ==========================================
# Diagnostic / Cache Directories
# ==========================================
**/.eslintcache
**/.stylelintcache
**/.cache/
**/.parcel-cache/
**/.turbo/
